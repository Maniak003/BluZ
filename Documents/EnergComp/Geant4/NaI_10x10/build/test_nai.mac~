# test_nai.mac - ИСПРАВЛЕННАЯ ВЕРСИЯ

# Сначала инициализируем ран (обязательно перед /gun/)
/run/initialize

# Теперь задаём параметры частицы
/gun/particle gamma
/gun/energy 662 keV

# Позиция источника: 5 см перед кристаллом (кристалл в центре 0,0,0)
/gun/position 0 0 -5 cm

# Направление: вдоль оси Z к кристаллу
/gun/direction 0 0 1

# Запускаем моделирование
/run/beamOn 10000
