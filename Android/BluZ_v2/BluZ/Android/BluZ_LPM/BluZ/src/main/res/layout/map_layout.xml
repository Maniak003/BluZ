<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/map_Layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bz_bg">

    <!-- Full-screen map -->
    <com.yandex.mapkit.mapview.MapView
        android:id="@+id/mapview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Header overlay -->
    <LinearLayout
        android:id="@+id/mapHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_bz_map_header_scrim"
        android:paddingStart="14dp"
        android:paddingTop="10dp"
        android:paddingEnd="14dp"
        android:paddingBottom="14dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="КАРТА · GPS ТРЕК"
                android:textColor="@color/bz_text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:fontFamily="@font/bz_inter_bold" />

            <TextView
                android:id="@+id/textCurrentTrack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Трек не выбран"
                android:textColor="@color/bz_text"
                android:textSize="18sp"
                android:fontFamily="@font/bz_inter_bold"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Floating action buttons (right side) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/mapActionBar">

        <ImageButton
            android:id="@+id/buttonMapLocate"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_bz_icon_button"
            android:src="@drawable/ic_bz_target"
            android:tint="@color/bz_info"
            android:scaleType="centerInside"
            android:contentDescription="Locate" />

        <ImageButton
            android:id="@+id/buttonAddPoint"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_bz_icon_button"
            android:src="@drawable/ic_bz_pin"
            android:tint="@color/bz_accent"
            android:scaleType="centerInside"
            android:contentDescription="Add point" />
    </LinearLayout>

    <!-- Bottom action bar — track controls -->
    <LinearLayout
        android:id="@+id/mapActionBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_bz_card"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="14dp"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/buttonRecord"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1.4"
            android:background="@drawable/bg_bz_button_accent"
            android:text="@string/textRecord"
            android:textAllCaps="false"
            android:textColor="@color/bz_on_accent"
            android:textSize="12sp"
            android:textStyle="bold"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:fontFamily="@font/bz_inter_bold" />

        <Button
            android:id="@+id/buttonTracks"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_bz_icon_button"
            android:text="@string/textTrack"
            android:textAllCaps="false"
            android:textColor="@color/bz_accent"
            android:textSize="12sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:fontFamily="@font/bz_inter_bold" />

        <Button
            android:id="@+id/buttonNewTrack"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_bz_icon_button"
            android:text="@string/newTarck"
            android:textAllCaps="false"
            android:textColor="@color/bz_accent"
            android:textSize="12sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:fontFamily="@font/bz_inter_bold" />

        <Button
            android:id="@+id/buttonSaveTrack"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_bz_icon_button"
            android:text="@string/saveMAP"
            android:textAllCaps="false"
            android:textColor="@color/bz_accent"
            android:textSize="12sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:fontFamily="@font/bz_inter_bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
