<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/spectrLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bz_bg">

    <!-- Title row + Save + Start/Stop -->
    <LinearLayout
        android:id="@+id/specTitleRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="1dp"
        android:paddingEnd="14dp"
        android:paddingBottom="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/bzSpecSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bz_inter_bold"
                android:letterSpacing="0.12"
                android:maxLines="1"
                android:text="КАНАЛ · 2048 · 0 – 3 МэВ"
                android:textColor="@color/bz_text_muted"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/bzSpecTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bz_inter_bold"
                    android:maxLines="1"
                    android:text="Гамма-спектр"
                    android:textColor="@color/bz_text"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/textTotalCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/bz_inter_bold"
                    android:text="TextView"
                    android:textAlignment="center"
                    android:textColor="@color/bz_text"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>

        <ImageButton
            android:id="@+id/buttonSaveBQ"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_bz_icon_button"
            android:contentDescription="Save"
            android:src="@drawable/ic_bz_save"
            app:tint="@color/bz_text" />

        <ImageButton
            android:id="@+id/buttonSpecterSS"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_bz_circle_accent"
            android:contentDescription="Start/Stop"
            android:scaleType="center"
            android:src="@drawable/ic_bz_play"
            app:tint="@color/bz_on_accent" />
    </LinearLayout>

    <!-- Hero readouts: dose rate / average -->
    <LinearLayout
        android:id="@+id/specHero"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="1dp"
        android:paddingEnd="18dp"
        android:paddingBottom="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/specTitleRow">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bz_inter_bold"
                android:letterSpacing="0.12"
                android:text="МОЩНОСТЬ ДОЗЫ"
                android:textColor="@color/bz_text_muted"
                android:textSize="10sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="bottom"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/bzSpecDoseValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bz_jetbrains_mono_bold"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="0.00"
                    android:textColor="@color/bz_accent"
                    android:textSize="30sp" />

                <TextView
                    android:id="@+id/bzSpecDoseUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="@font/bz_jetbrains_mono"
                    android:text="мкР/ч"
                    android:textColor="@color/bz_text_dim"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bz_inter_bold"
                android:letterSpacing="0.12"
                android:text="СРЕДНЯЯ"
                android:textColor="@color/bz_text_muted"
                android:textSize="10sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="bottom"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/bzSpecAvgValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bz_jetbrains_mono_bold"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="0.00"
                    android:textColor="@color/bz_text"
                    android:textSize="30sp" />

                <TextView
                    android:id="@+id/bzSpecAvgUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="@font/bz_jetbrains_mono"
                    android:text="мкР/ч"
                    android:textColor="@color/bz_text_dim"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Chart card -->
    <LinearLayout
        android:id="@+id/specChartCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="1dp"
        android:layout_marginEnd="1dp"
        android:background="@drawable/bg_bz_card"
        android:orientation="vertical"
        android:padding="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/specHero">

        <!-- Chart canvas overlay container.
             Стек снизу вверх: specterView (живой спектр) / historyView (история, gone по умолчанию) / cursorView (overlay курсора).
             Page change в specBottomPager переключает видимость specterView <-> historyView и скрывает cursorView для history. -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/specterView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <ImageView
                android:id="@+id/cursorView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clickable="true"
                android:focusable="true" />

            <!-- Информация об изотопе под курсором (только при наличии калибровки) -->
            <TextView
                android:id="@+id/textIsotopInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="6dp"
                android:background="#99000000"
                android:fontFamily="@font/bz_jetbrains_mono_bold"
                android:paddingStart="8dp"
                android:paddingTop="3dp"
                android:paddingEnd="8dp"
                android:paddingBottom="3dp"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:visibility="invisible" />
        </FrameLayout>

        <!-- Toolbar inside card -->
        <LinearLayout
            android:id="@+id/specToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="2dp"
            android:paddingBottom="2dp">

            <CheckBox
                android:id="@+id/cbSMA"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:buttonTint="@color/bz_accent"
                android:minWidth="0dp"
                android:text="SMA"
                android:textColor="@color/bz_text_dim"
                android:textSize="10sp" />

            <CheckBox
                android:id="@+id/cbMED"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:buttonTint="@color/bz_accent"
                android:minWidth="0dp"
                android:text="MED"
                android:textColor="@color/bz_text_dim"
                android:textSize="10sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/buttonCalibrate"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_bz_icon_button"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="1"
                android:textColor="@color/bz_text_dim"
                android:textSize="11sp" />

            <Button
                android:id="@+id/buttonConfirmCalibrate"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_bz_icon_button"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="X"
                android:textColor="@color/bz_text_dim"
                android:textSize="11sp" />

            <ImageButton
                android:id="@+id/buttonClearSpectr"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_bz_icon_button"
                android:contentDescription="Clear"
                android:src="@drawable/ic_bz_clear"
                app:tint="@color/bz_danger" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom swipe pager: page 0 = measurement clock, page 1 = history readouts/controls -->

    <!-- Legacy hidden: buttonLoadSpectr (referenced nowhere but kept for safety) -->
    <Button
        android:id="@+id/buttonLoadSpectr"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
