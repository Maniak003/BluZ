<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground"
    android:paddingStart="14dp"
    android:paddingEnd="6dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/bzScanItemMac"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="XX:XX:XX:XX:XX:XX"
        android:textColor="@color/bz_text"
        android:textSize="14sp"
        android:fontFamily="@font/bz_jetbrains_mono_bold"
        android:maxLines="1"
        android:ellipsize="middle" />

    <ImageButton
        android:id="@+id/bzScanItemBell"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_bz_icon_button"
        android:src="@drawable/ic_bz_bell"
        app:tint="@color/bz_accent"
        android:contentDescription="Ping device" />
</LinearLayout>
