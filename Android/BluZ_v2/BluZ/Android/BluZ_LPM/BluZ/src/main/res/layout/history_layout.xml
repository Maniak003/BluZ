<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/history_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bz_bg">

    <!-- Title -->
    <LinearLayout
        android:id="@+id/histTitleRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="10dp"
        android:paddingEnd="18dp"
        android:paddingBottom="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ИСТОРИЯ · НАКОПЛЕННЫЙ СПЕКТР"
            android:textColor="@color/bz_text_muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:fontFamily="@font/bz_inter_bold" />

        <TextView
            android:id="@+id/bzHistDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textColor="@color/bz_text"
            android:textSize="22sp"
            android:fontFamily="@font/bz_jetbrains_mono_bold" />
    </LinearLayout>

    <!-- Hero readouts -->
    <LinearLayout
        android:id="@+id/histHero"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="1dp"
        android:paddingEnd="1dp"
        android:paddingBottom="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/histTitleRow">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bz_inter_bold"
                android:letterSpacing="0.12"
                android:text="ИНТЕГРАЛ"
                android:textColor="@color/bz_text_muted"
                android:textSize="10sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="bottom"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/bzHistIntegralValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bz_jetbrains_mono_bold"
                    android:includeFontPadding="false"
                    android:text="0"
                    android:textColor="@color/bz_accent"
                    android:textSize="26sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="3dp"
                    android:fontFamily="@font/bz_jetbrains_mono"
                    android:text="имп"
                    android:textColor="@color/bz_text_dim"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bz_inter_bold"
                android:letterSpacing="0.12"
                android:text="СР. CPS"
                android:textColor="@color/bz_text_muted"
                android:textSize="10sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="bottom"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/bzHistAvgCpsValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bz_jetbrains_mono_bold"
                    android:includeFontPadding="false"
                    android:text="0.00"
                    android:textColor="@color/bz_text"
                    android:textSize="26sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="3dp"
                    android:fontFamily="@font/bz_jetbrains_mono"
                    android:text="имп/с"
                    android:textColor="@color/bz_text_dim"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Chart card -->
    <FrameLayout
        android:id="@+id/histChartCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="1dp"
        android:layout_marginEnd="1dp"
        android:background="@drawable/bg_bz_card"
        android:padding="1dp"
        app:layout_constraintBottom_toTopOf="@id/histActions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/histHero">

        <ImageView
            android:id="@+id/historyView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ImageView
            android:id="@+id/historyCursorView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/textHistoryIsotop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="6dp"
            android:background="#99000000"
            android:fontFamily="@font/bz_jetbrains_mono_bold"
            android:paddingStart="8dp"
            android:paddingTop="3dp"
            android:paddingEnd="8dp"
            android:paddingBottom="3dp"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:visibility="invisible" />
    </FrameLayout>

    <!-- Action row -->
    <LinearLayout
        android:id="@+id/histActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <CheckBox
            android:id="@+id/cbHistorySMA"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:buttonTint="@color/bz_accent"
            android:text="SMA"
            android:textColor="@color/bz_text_dim"
            android:textSize="10sp" />

        <Button
            android:id="@+id/buttonLoadHistory"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_bz_icon_button"
            android:fontFamily="@font/bz_inter_bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="@string/textLoadSpectr"
            android:textAllCaps="false"
            android:textColor="@color/bz_accent"
            android:textSize="12sp" />

        <Button
            android:id="@+id/buttonHistorySave"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_bz_icon_button"
            android:fontFamily="@font/bz_inter_bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="@string/textSaveBQ"
            android:textAllCaps="false"
            android:textColor="@color/bz_accent"
            android:textSize="12sp" />

        <ImageButton
            android:id="@+id/buttonClearHistory"
            android:layout_width="44dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_bz_icon_button"
            android:contentDescription="Clear"
            android:src="@drawable/ic_bz_clear"
            app:tint="@color/bz_danger" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
