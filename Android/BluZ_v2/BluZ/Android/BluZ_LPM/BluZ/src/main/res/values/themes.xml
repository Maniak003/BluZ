<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.BluZ" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/bz_accent</item>
        <item name="colorOnPrimary">@color/bz_on_accent</item>
        <item name="colorSecondary">@color/bz_accent_2</item>
        <item name="colorSurface">@color/bz_surface</item>
        <item name="colorOnSurface">@color/bz_text</item>
        <item name="colorSurfaceVariant">@color/bz_surface_2</item>
        <item name="colorOnSurfaceVariant">@color/bz_text_dim</item>
        <item name="colorOutline">@color/bz_line</item>
        <item name="android:colorBackground">@color/bz_bg</item>
        <item name="android:statusBarColor">@color/bz_bg</item>
        <item name="android:navigationBarColor">@color/bz_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    </style>

    <style name="Theme.BluZ" parent="Base.Theme.BluZ" />

    <style name="Theme.BluZ.Fullscreen" parent="Base.Theme.BluZ">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
