<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/history_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bz_bg">

    <!-- Compact hero row + actions -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/histHero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="1dp"
            android:paddingEnd="14dp"
            android:paddingBottom="1dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bz_inter_bold"
                    android:letterSpacing="0.12"
                    android:text="ИНТЕГРАЛ"
                    android:textColor="@color/bz_text_muted"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="bottom"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/bzHistIntegralValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/bz_jetbrains_mono_bold"
                        android:includeFontPadding="false"
                        android:text="0"
                        android:textColor="@color/bz_accent"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:layout_marginBottom="3dp"
                        android:fontFamily="@font/bz_jetbrains_mono"
                        android:text="имп"
                        android:textColor="@color/bz_text_dim"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="28dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="@color/bz_line" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/bz_inter_bold"
                    android:letterSpacing="0.12"
                    android:text="СР. CPS"
                    android:textColor="@color/bz_text_muted"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="bottom"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/bzHistAvgCpsValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/bz_jetbrains_mono_bold"
                        android:includeFontPadding="false"
                        android:text="0.00"
                        android:textColor="@color/bz_text"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:layout_marginBottom="3dp"
                        android:fontFamily="@font/bz_jetbrains_mono"
                        android:text="имп/с"
                        android:textColor="@color/bz_text_dim"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginStart="2dp"
            android:layout_marginTop="1dp"
            android:layout_marginEnd="2dp"
            android:layout_marginBottom="1dp"
            android:layout_weight="1"
            android:background="@drawable/bg_bz_card"
            android:padding="1dp">

            <ImageView
                android:id="@+id/historyView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <ImageView
                android:id="@+id/historyCursorView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:srcCompat="@drawable/bg_bz_chip_accent" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/bzHistDuration"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <CheckBox
                android:id="@+id/cbHistorySMA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:buttonTint="@color/bz_accent"
                android:text="SMA"
                android:textColor="@color/bz_text_dim"
                android:textSize="10sp" />

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <Button
                android:id="@+id/buttonLoadHistory"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_bz_icon_button"
                android:fontFamily="@font/bz_inter_bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="@string/textLoadSpectr"
                android:textAllCaps="false"
                android:textColor="@color/bz_accent"
                android:textSize="11sp" />

            <Button
                android:id="@+id/buttonHistorySave"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_bz_icon_button"
                android:fontFamily="@font/bz_inter_bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="@string/textSaveBQ"
                android:textAllCaps="false"
                android:textColor="@color/bz_accent"
                android:textSize="11sp"
                android:visibility="visible" />

            <ImageButton
                android:id="@+id/buttonClearHistory"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_bz_icon_button"
                android:contentDescription="Clear"
                android:src="@drawable/ic_bz_clear"
                android:visibility="visible"
                app:tint="@color/bz_danger" />
        </LinearLayout>

    </LinearLayout>

    <!-- Hidden duration legacy id (portrait only) -->

</androidx.constraintlayout.widget.ConstraintLayout>
