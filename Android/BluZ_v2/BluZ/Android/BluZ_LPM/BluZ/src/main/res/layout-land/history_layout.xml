<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/history_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bz_bg">

    <!-- Compact hero row + actions -->
    <LinearLayout
        android:id="@+id/histHero"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingTop="8dp"
        android:paddingEnd="14dp"
        android:paddingBottom="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ИНТЕГРАЛ"
                android:textColor="@color/bz_text_muted"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:fontFamily="@font/bz_inter_bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">

                <TextView
                    android:id="@+id/bzHistIntegralValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/bz_accent"
                    android:textSize="20sp"
                    android:includeFontPadding="false"
                    android:fontFamily="@font/bz_jetbrains_mono_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:layout_marginBottom="3dp"
                    android:text="имп"
                    android:textColor="@color/bz_text_dim"
                    android:textSize="10sp"
                    android:fontFamily="@font/bz_jetbrains_mono" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:background="@color/bz_line" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="СР. CPS"
                android:textColor="@color/bz_text_muted"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:fontFamily="@font/bz_inter_bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">

                <TextView
                    android:id="@+id/bzHistAvgCpsValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:textColor="@color/bz_text"
                    android:textSize="20sp"
                    android:includeFontPadding="false"
                    android:fontFamily="@font/bz_jetbrains_mono_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:layout_marginBottom="3dp"
                    android:text="имп/с"
                    android:textColor="@color/bz_text_dim"
                    android:textSize="10sp"
                    android:fontFamily="@font/bz_jetbrains_mono" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/buttonLoadHistory"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_bz_icon_button"
            android:text="@string/textLoadSpectr"
            android:textAllCaps="false"
            android:textColor="@color/bz_accent"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:fontFamily="@font/bz_inter_bold" />

        <Button
            android:id="@+id/buttonHistorySave"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_bz_icon_button"
            android:text="@string/textSaveBQ"
            android:textAllCaps="false"
            android:textColor="@color/bz_accent"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:fontFamily="@font/bz_inter_bold" />

        <ImageButton
            android:id="@+id/buttonClearHistory"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_bz_icon_button"
            android:src="@drawable/ic_bz_clear"
            app:tint="@color/bz_danger"
            android:contentDescription="Clear" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_bz_card"
        android:layout_marginStart="14dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="10dp"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/histHero"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/historyView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <!-- Hidden duration legacy id (portrait only) -->
    <TextView
        android:id="@+id/bzHistDuration"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
