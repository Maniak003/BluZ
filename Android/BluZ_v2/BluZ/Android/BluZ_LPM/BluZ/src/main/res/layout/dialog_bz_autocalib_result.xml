<?xml version="1.0" encoding="utf-8"?>
<!-- Стилизованный диалог результата автокалибровки. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bz_bg"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="18dp"
    android:paddingBottom="18dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Результат автокалибровки"
        android:textColor="@color/bz_text"
        android:textSize="18sp"
        android:fontFamily="@font/bz_inter_bold"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:minHeight="120dp"
        android:maxHeight="380dp"
        android:fillViewport="true">

        <TextView
            android:id="@+id/bzCalibResultBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/bz_text"
            android:textSize="12sp"
            android:fontFamily="@font/bz_jetbrains_mono"
            android:lineSpacingMultiplier="1.3" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="14dp">

        <Button
            android:id="@+id/bzCalibResultCancel"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:background="@drawable/bg_bz_icon_button"
            android:text="Отмена"
            android:textAllCaps="false"
            android:textColor="@color/bz_text_dim"
            android:textSize="13sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:fontFamily="@font/bz_inter_bold" />

        <Button
            android:id="@+id/bzCalibResultApply"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_bz_icon_button"
            android:text="Применить"
            android:textAllCaps="false"
            android:textColor="@color/bz_accent"
            android:textSize="13sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:fontFamily="@font/bz_inter_bold" />
    </LinearLayout>
</LinearLayout>
